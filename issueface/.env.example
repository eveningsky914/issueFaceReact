# ── The Guardian API (뉴스 fetch용) ───────────────────────────────
# 무료 발급: https://open-platform.theguardian.com/access/
# 이메일만 있으면 즉시 발급, 하루 500건 무료
# 없으면 'test' 키로도 동작하지만 rate limit 있음
REACT_APP_GUARDIAN_KEY=your_guardian_key_here

# ── GNews API (선택사항, 있으면 Guardian 대신 사용) ───────────────
# 무료 발급: https://gnews.io
# 하루 100건 무료
REACT_APP_GNEWS_KEY=
